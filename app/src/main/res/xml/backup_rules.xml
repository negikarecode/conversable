<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules file for Conversable app.
   See https://developer.android.com/guide/topics/data/autobackup for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Exclude sensitive data from cloud backup -->
    <exclude domain="sharedpref" path="conversable_prefs.xml"/>
    <exclude domain="database" path="conversable_database"/>
</full-backup-content>
