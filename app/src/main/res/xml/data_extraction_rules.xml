<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules file for Conversable app.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="conversable_prefs.xml"/>
        <exclude domain="database" path="conversable_database"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive data from device transfer -->
        <exclude domain="sharedpref" path="conversable_prefs.xml"/>
        <exclude domain="database" path="conversable_database"/>
    </device-transfer>
</data-extraction-rules>
